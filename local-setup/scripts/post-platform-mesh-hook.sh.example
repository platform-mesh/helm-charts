#!/bin/bash
SCRIPT_DIR=$(dirname "$0")
# This script is sourced by start.sh after the PlatformMesh resource is ready and kcp is accessible.
# Copy this file to post-platform-mesh-hook.sh and customize it for your needs.
# The post-platform-mesh-hook.sh file is gitignored, so your local changes won't be committed.
#
# At this point in the setup, the following is available:
#   - Kind cluster with TLS certificates
#   - Flux, KRO, OCM
#   - Platform-Mesh Operator (ready)
#   - PlatformMesh resource (ready)
#   - kcp admin kubeconfig (via $KCP_KUBECONFIG)
#
# You can use this hook to:
#   - Create kcp workspaces
#   - Deploy resources into kcp
#   - Apply additional platform-level configuration
#
# Usage:
#   cp post-platform-mesh-hook.sh.example post-platform-mesh-hook.sh
#   # Edit post-platform-mesh-hook.sh with your customizations
#   task local-setup:iterate

# Example: Create a workspace in kcp
# KUBECONFIG="$KCP_KUBECONFIG" kubectl create-workspace my-workspace --type=root:providers --ignore-existing --server="https://localhost:8443/clusters/root"

# Example: Apply resources into a kcp workspace
# KUBECONFIG="$KCP_KUBECONFIG" kubectl apply -f my-resources.yaml --server="https://localhost:8443/clusters/root:my-workspace"

# Example: Deploy a Flux HelmRelease into the host cluster
# kubectl apply -f - <<EOF
# apiVersion: helm.toolkit.fluxcd.io/v2
# kind: HelmRelease
# metadata:
#   name: my-release
#   namespace: default
# spec:
#   interval: 1h
#   chart:
#     spec:
#       chart: my-chart
#       version: "1.0.0"
#       sourceRef:
#         kind: HelmRepository
#         name: my-repo
# EOF

  4: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app: platform-mesh-kubernetes-graphql-gateway
      name: platform-mesh-kubernetes-graphql-gateway
      namespace: platform-mesh-system
    spec:
      replicas: 1
      revisionHistoryLimit: 3
      selector:
        matchLabels:
          app: platform-mesh-kubernetes-graphql-gateway
      strategy:
        rollingUpdate:
          maxSurge: 5
          maxUnavailable: 0
      template:
        metadata:
          labels:
            app: platform-mesh-kubernetes-graphql-gateway
            version: 1.0.0
        spec:
          containers:
            - args:
                - gateway
                - --schema-handler=grpc
                - --grpc-listener-address=platform-mesh-kubernetes-graphql-gateway-listener.platform-mesh-system.svc.cluster.local:50051
              env:
                - name: KUBECONFIG
                  value: /app/kubeconfig/kubeconfig
              image: ghcr.io/openmfp/kubernetes-graphql-gateway:1.0.0
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 1
                httpGet:
                  path: /healthz
                  port: 3389
                periodSeconds: 10
              name: gateway
              ports:
                - containerPort: 8081
                  name: metrics
                  protocol: TCP
                - containerPort: 3389
                  name: health-port
                  protocol: TCP
                - containerPort: 8080
                  name: service-port
                  protocol: TCP
              readinessProbe:
                httpGet:
                  path: /readyz
                  port: 3389
                initialDelaySeconds: 5
                periodSeconds: 10
              resources:
                limits:
                  memory: 1200Mi
                requests:
                  cpu: 250m
                  memory: 1000Mi
              securityContext:
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                seccompProfile:
                  type: RuntimeDefault
              startupProbe:
                failureThreshold: 30
                httpGet:
                  path: /readyz
                  port: 3389
                periodSeconds: 10
              volumeMounts:
                - mountPath: /app/kubeconfig
                  name: kubeconfig-volume
          serviceAccountName: platform-mesh-kubernetes-graphql-gateway
          volumes:
            - name: kubeconfig-volume
              secret:
                secretName: kcp-root-kubeconfig
  5: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app: platform-mesh-kubernetes-graphql-gateway-listener
      name: platform-mesh-kubernetes-graphql-gateway-listener
      namespace: platform-mesh-system
    spec:
      replicas: 1
      revisionHistoryLimit: 3
      selector:
        matchLabels:
          app: platform-mesh-kubernetes-graphql-gateway-listener
      strategy:
        rollingUpdate:
          maxSurge: 5
          maxUnavailable: 0
      template:
        metadata:
          labels:
            app: platform-mesh-kubernetes-graphql-gateway-listener
            version: 1.0.0
        spec:
          containers:
            - args:
                - listener
                - --schema-handler=grpc
                - --grpc-listen-addr=:50051
                - --multicluster-runtime-provider=multi
                - --kubeconfig=/app/kubeconfig/kubeconfig
                - --apiexport-endpoint-slice-name=core.platform-mesh.io
                - --workspace-schema-kubeconfig-override=/app/kubeconfig/kubeconfig
                - --anchor-resource=true
                - --reconciler-gvr=apibindings.v1alpha2.apis.kcp.io
                - --additional-path-annotation-key=kcp.io/path
                - --metrics-bind-address=:8091
                - --enable-resource-controller=true
                - --enable-clusteraccess-controller=true
                - --single-kubeconfig=/app/single-kubeconfig/kubeconfig
                - --resource-controller-providers=kcp
                - --clusteraccess-controller-providers=single
              env:
                - name: KUBECONFIG
                  value: /app/kubeconfig/kubeconfig
              image: ghcr.io/openmfp/kubernetes-graphql-gateway:1.0.0
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 1
                httpGet:
                  path: /healthz
                  port: 3390
                periodSeconds: 10
              name: listener
              ports:
                - containerPort: 50051
                  name: grpc
                  protocol: TCP
                - containerPort: 8091
                  name: metrics
                  protocol: TCP
                - containerPort: 3390
                  name: health-port
                  protocol: TCP
                - containerPort: 8090
                  name: service-port
                  protocol: TCP
              readinessProbe:
                httpGet:
                  path: /readyz
                  port: 3390
                initialDelaySeconds: 5
                periodSeconds: 10
              resources:
                limits:
                  memory: 600Mi
                requests:
                  cpu: 250m
                  memory: 500Mi
              securityContext:
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                seccompProfile:
                  type: RuntimeDefault
              startupProbe:
                failureThreshold: 30
                httpGet:
                  path: /readyz
                  port: 3390
                periodSeconds: 10
              volumeMounts:
                - mountPath: /app/kubeconfig
                  name: kubeconfig-volume
                - mountPath: /app/single-kubeconfig
                  name: single-kubeconfig-volume
          serviceAccountName: platform-mesh-kubernetes-graphql-gateway
          volumes:
            - name: kubeconfig-volume
              secret:
                secretName: kcp-root-kubeconfig
            - name: single-kubeconfig-volume
              secret:
                secretName: single-kubeconfig
  6: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: HTTPRoute
    metadata:
      name: platform-mesh-kubernetes-graphql-gateway
      namespace: platform-mesh-system
    spec:
      hostnames:
        - portal.localhost
        - '*.portal.localhost'
      parentRefs:
        - name: k8sapi-gateway
      rules:
        - backendRefs:
            - name: platform-mesh-kubernetes-graphql-gateway
              namespace: platform-mesh-system
              port: 8080
          filters:
            - type: URLRewrite
              urlRewrite:
                path:
                  replacePrefixMatch: /api/clusters/
                  type: ReplacePrefixMatch
            - extensionRef:
                group: traefik.io
                kind: Middleware
                name: cors-header
              type: ExtensionRef
          matches:
            - path:
                type: PathPrefix
                value: /gateway/api/clusters/
  7: |
    apiVersion: v1
    kind: ServiceAccount
    metadata:
      name: platform-mesh-kubernetes-graphql-gateway
      namespace: platform-mesh-system
  8: |
    apiVersion: v1
    kind: Service
    metadata:
      name: platform-mesh-kubernetes-graphql-gateway
      namespace: platform-mesh-system
    spec:
      ports:
        - name: http
          port: 8080
          protocol: TCP
          targetPort: 8080
        - name: health
          port: 3389
          protocol: TCP
          targetPort: 3389
        - name: metrics
          port: 8081
          protocol: TCP
          targetPort: 8081
      selector:
        app: platform-mesh-kubernetes-graphql-gateway
      type: ClusterIP
  9: |
    apiVersion: v1
    kind: Service
    metadata:
      name: platform-mesh-kubernetes-graphql-gateway-listener
      namespace: platform-mesh-system
    spec:
      ports:
        - name: grpc
          port: 50051
          protocol: TCP
          targetPort: 50051
        - name: metrics
          port: 8091
          protocol: TCP
          targetPort: 8091
        - name: health
          port: 3390
          protocol: TCP
          targetPort: 3390
      selector:
        app: platform-mesh-kubernetes-graphql-gateway-listener
      type: ClusterIP
  10: |
    apiVersion: v1
    kind: Secret
    metadata:
      name: single-kubeconfig
      namespace: platform-mesh-system
    stringData:
      kubeconfig: |
        apiVersion: v1
        kind: Config
        clusters:
        - cluster:
            certificate-authority: /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
            server: https://kubernetes.default.svc
          name: default
        contexts:
        - context:
            cluster: default
            user: default
          name: default
        current-context: default
        users:
        - name: default
          user:
            tokenFile: /var/run/secrets/kubernetes.io/serviceaccount/token
    type: Opaque

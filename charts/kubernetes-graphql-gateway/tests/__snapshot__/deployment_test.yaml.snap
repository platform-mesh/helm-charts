has all hostAliases configured:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app: platform-mesh-kubernetes-graphql-gateway
      name: platform-mesh-kubernetes-graphql-gateway
      namespace: platform-mesh-system
    spec:
      replicas: 1
      revisionHistoryLimit: 3
      selector:
        matchLabels:
          app: platform-mesh-kubernetes-graphql-gateway
      strategy:
        rollingUpdate:
          maxSurge: 5
          maxUnavailable: 0
      template:
        metadata:
          labels:
            app: platform-mesh-kubernetes-graphql-gateway
            schema-handler-group: platform-mesh-kubernetes-graphql-gateway
            version: 1.0.0
        spec:
          affinity:
            podAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                - labelSelector:
                    matchLabels:
                      schema-handler-group: platform-mesh-kubernetes-graphql-gateway
                  topologyKey: kubernetes.io/hostname
          containers:
            - args:
                - gateway
                - --schema-handler=file
                - --schemas-dir=/app/schemas
                - --tracing-enabled=true
                - --tracing-config-service-name=platform-mesh-kubernetes-graphql-gateway.platform-mesh-system
                - --tracing-config-service-version=1.0.0
                - --tracing-config-collector-endpoint=observability-opentelemetry-collector.platform-mesh-observability.svc.cluster.local:4317
              env: null
              image: ghcr.io/openmfp/kubernetes-graphql-gateway:1.0.0
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 1
                httpGet:
                  path: /healthz
                  port: 3389
                periodSeconds: 10
              name: gateway
              ports:
                - containerPort: 8081
                  name: metrics
                  protocol: TCP
                - containerPort: 3389
                  name: health-port
                  protocol: TCP
                - containerPort: 8080
                  name: service-port
                  protocol: TCP
              readinessProbe:
                httpGet:
                  path: /readyz
                  port: 3389
                initialDelaySeconds: 5
                periodSeconds: 10
              resources:
                limits:
                  memory: 1200Mi
                requests:
                  cpu: 250m
                  memory: 1000Mi
              securityContext:
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                seccompProfile:
                  type: RuntimeDefault
              startupProbe:
                failureThreshold: 30
                httpGet:
                  path: /readyz
                  port: 3389
                periodSeconds: 10
              volumeMounts:
                - mountPath: /app/schemas
                  name: definitions-volume
                  readOnly: true
          hostAliases:
            - hostnames:
                - example.com
                - test.example.com
              ip: 10.0.0.1
          serviceAccountName: platform-mesh-kubernetes-graphql-gateway
          volumes:
            - name: definitions-volume
              persistentVolumeClaim:
                claimName: platform-mesh-kubernetes-graphql-gateway-schemas
  2: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app: platform-mesh-kubernetes-graphql-gateway-listener
      name: platform-mesh-kubernetes-graphql-gateway-listener
      namespace: platform-mesh-system
    spec:
      replicas: 1
      revisionHistoryLimit: 3
      selector:
        matchLabels:
          app: platform-mesh-kubernetes-graphql-gateway-listener
      strategy:
        rollingUpdate:
          maxSurge: 5
          maxUnavailable: 0
      template:
        metadata:
          labels:
            app: platform-mesh-kubernetes-graphql-gateway-listener
            schema-handler-group: platform-mesh-kubernetes-graphql-gateway
            version: 1.0.0
        spec:
          affinity:
            podAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                - labelSelector:
                    matchLabels:
                      schema-handler-group: platform-mesh-kubernetes-graphql-gateway
                  topologyKey: kubernetes.io/hostname
          containers:
            - args:
                - listener
                - --schema-handler=file
                - --schemas-dir=/app/schemas
                - --multicluster-runtime-provider=kcp
                - --apiexport-endpoint-slice-name=core.platform-mesh.io
                - --workspace-schema-kubeconfig-override=/app/kubeconfig/kubeconfig
                - --anchor-resource=object.metadata.name.startsWith("core.platform-mesh.io")
                - --reconciler-gvr=apibindings.v1alpha2.apis.kcp.io
                - --additional-path-annotation-key=kcp.io/path
                - --metrics-bind-address=:8091
              env: null
              image: ghcr.io/openmfp/kubernetes-graphql-gateway:1.0.0
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 1
                httpGet:
                  path: /healthz
                  port: 3390
                periodSeconds: 10
              name: listener
              ports:
                - containerPort: 8091
                  name: metrics
                  protocol: TCP
                - containerPort: 3390
                  name: health-port
                  protocol: TCP
                - containerPort: 8090
                  name: service-port
                  protocol: TCP
              readinessProbe:
                httpGet:
                  path: /readyz
                  port: 3390
                initialDelaySeconds: 5
                periodSeconds: 10
              resources:
                limits:
                  memory: 600Mi
                requests:
                  cpu: 250m
                  memory: 500Mi
              securityContext:
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                seccompProfile:
                  type: RuntimeDefault
              startupProbe:
                failureThreshold: 30
                httpGet:
                  path: /readyz
                  port: 3390
                periodSeconds: 10
              volumeMounts:
                - mountPath: /app/schemas
                  name: definitions-volume
                - mountPath: /app/config
                  name: virtual-workspaces-config-volume
          hostAliases:
            - hostnames:
                - example.com
                - test.example.com
              ip: 10.0.0.1
          serviceAccountName: platform-mesh-kubernetes-graphql-gateway
          volumes:
            - name: definitions-volume
              persistentVolumeClaim:
                claimName: platform-mesh-kubernetes-graphql-gateway-schemas
            - configMap:
                name: virtual-workspaces-config
              name: virtual-workspaces-config-volume
